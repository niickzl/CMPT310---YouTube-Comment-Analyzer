{
  "manifest_version": 3,
  "name": "YT Comment Analyzer",
  "version": "1.0",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch?v=*"],
      "js": ["content.js"]
    }
  ]
}